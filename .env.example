# Copy to .env and fill in your values
# cp .env.example .env

# Required
BIRKIN_TOKEN=your-secret-token-here
WEBUI_SECRET_KEY=your-webui-secret-here

# Optional
BIRKIN_PORT=3000
BIRKIN_BUDGET_USD=50
ENABLE_SIGNUP=false

# Push notifications — fill ONE provider or leave blank
# Pusher Beams (https://pusher.com/beams):
# PUSHER_INSTANCE_ID=
# PUSHER_SECRET_KEY=
# OneSignal (https://onesignal.com):
# ONESIGNAL_APP_ID=
# ONESIGNAL_API_KEY=
